{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/downloads/PAKToolInstallation.exe",
      "destination": "/downloads/KiroSetup.exe",
      "permanent": true
    },
    {
      "source": "/downloads/PAKToolInstallation.exe.sha256",
      "destination": "/downloads/KiroSetup.exe.sha256",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/downloads/KiroSetup.exe",
      "headers": [
        {
          "key": "Content-Disposition",
          "value": "attachment; filename=\"KiroSetup.exe\""
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/downloads/KiroSetup.exe.sha256",
      "headers": [
        {
          "key": "Content-Disposition",
          "value": "attachment; filename=\"KiroSetup.exe.sha256\""
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/images/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
